# Private iOS App Store Environment Variables
# Copy this file to .env and configure if needed.

# Server Configuration
PORT=8080

# Note: DO NOT store your Apple ID, App Store Connect API keys, or passwords here.
# SideStore uses local pairing files and safe device login directly on the iPhone.
STORE_USER=jaeseok
STORE_PASS=change-this-password
STORE_SESSION_SECRET=change-this-long-random-session-secret
STORE_DOWNLOAD_TOKEN=change-this-long-random-download-token
PORT=8085
